{
  "type": "object",
  "required": [
    "aiSummary",
    "keywordsZh",
    "keywordsEn",
    "semanticQueryZh"
  ],
  "properties": {
    "aiSummary": {
      "type": "object",
      "required": [
        "tldr",
        "motivation",
        "method",
        "result",
        "conclusion",
        "markdown"
      ],
      "properties": {
        "tldr": {
          "type": "string",
          "description": "One concise Chinese sentence for feed display."
        },
        "motivation": {
          "type": "string",
          "description": "Why this problem matters."
        },
        "method": {
          "type": "string",
          "description": "Main technical idea."
        },
        "result": {
          "type": "string",
          "description": "Reported effect, experiment, or result. Say if the abstract does not provide enough detail."
        },
        "conclusion": {
          "type": "string",
          "description": "Practical takeaway for readers."
        },
        "markdown": {
          "type": "string",
          "description": "A short Markdown summary with headings: TL;DR, 动机, 方法, 效果, 结论."
        }
      }
    },
    "keywordsZh": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 4,
      "maxItems": 10
    },
    "keywordsEn": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 4,
      "maxItems": 10
    },
    "semanticQueryZh": {
      "type": "string",
      "description": "A compact Chinese query sentence for semantic search and local recommendation."
    }
  }
}
